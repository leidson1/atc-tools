{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATC Tools - Sistema de Radiais",
  "version": "0.1.0",
  "identifier": "br.com.atctools.sistema-radiais",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sistema de Radiais - ATC Tools",
        "width": 1366,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
